{
  "id": "youtube-chat",
  "name": "YouTube Chat Overlay",
  "version": "1.0.0",
  "description": "Stunning YouTube Live chat overlay with Super Chat support, member badges, and smooth animations.",
  "author": "Stream Pack",
  "icon": "🔴",
  "category": "chat",
  "platform": "youtube",
  "platformColor": "#FF0000",
  "entry": "index.html",
  "tags": ["chat", "overlay", "youtube", "superchat"],
  "settings": [
    { "key": "videoId", "label": "Video ID", "type": "text", "default": "", "placeholder": "YouTube live video ID" },
    { "key": "demoMode", "label": "Demo Mode", "type": "toggle", "default": true },
    { "key": "maxMessages", "label": "Max Messages", "type": "number", "default": 12, "min": 5, "max": 30 },
    { "key": "fadeTimeout", "label": "Fade After (seconds)", "type": "number", "default": 30, "min": 5, "max": 120 },
    { "key": "showSuperChats", "label": "Show Super Chats", "type": "toggle", "default": true }
  ]
}
